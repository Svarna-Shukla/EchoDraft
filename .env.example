# Groq API key used for slide generation, Founder Kit, Competitor Radar, and Pitcherator
VITE_GROQ_API_KEY=your-groq-api-key-here

# ElevenLabs API key shared by every investor's spoken lines — falls back to browser
# speechSynthesis if unset. VITE_ELEVENLABS_VOICE_ID is a legacy fallback for Lord Vane only, kept
# for existing configs; prefer the per-investor VITE_VOICE_* keys below for new setups.
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=

# Per-investor ElevenLabs voice IDs — each investor speaks in their own cloned voice when set
VITE_VOICE_LORD_VANE=
VITE_VOICE_TECH_BRO=
VITE_VOICE_MOGUL=
VITE_VOICE_WILDCARD=
VITE_VOICE_MENTOR=
